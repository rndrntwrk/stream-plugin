  "pluginParameters": {
    "STREAM555_BASE_URL": {
      "type": "string",
      "description": "Legacy base URL override for all agents"
    },
    "STREAM555_PUBLIC_BASE_URL": {
      "type": "string",
      "description": "Public control-plane base URL for external agents",
      "default": "https://stream.rndrntwrk.com"
    },
    "STREAM555_INTERNAL_BASE_URL": {
      "type": "string",
      "description": "Internal control-plane base URL for allow-listed internal agents",
      "default": "http://control-plane:3000"
    },
    "STREAM555_INTERNAL_AGENT_IDS": {
      "type": "string",
      "description": "Comma-separated agent IDs that should use STREAM555_INTERNAL_BASE_URL",
      "default": "alice,alice-internal"
    },
    "STREAM555_AGENT_API_KEY": {
      "type": "string",
      "description": "Long-lived agent API key exchanged for short-lived JWTs",
      "sensitive": true
    },
    "STREAM555_AGENT_TOKEN": {
      "type": "string",
      "description": "Static bearer token for 555stream agent routes",
      "sensitive": true
    },
    "STREAM_API_BEARER_TOKEN": {
      "type": "string",
      "description": "Legacy bearer token fallback for agent route authentication",
      "sensitive": true
    },
    "STREAM555_AGENT_TOKEN_EXCHANGE_ENDPOINT": {
      "type": "string",
      "description": "Token exchange path",
      "default": "/api/agent/v1/auth/token/exchange"
    },
    "STREAM555_AGENT_TOKEN_REFRESH_WINDOW_SECONDS": {
      "type": "number",
      "description": "Token refresh buffer for exchanged JWTs",
      "default": 300
    },
    "STREAM555_DEFAULT_SESSION_ID": {
      "type": "string",
      "description": "Preferred 555stream session ID"
    },
    "STREAM_SESSION_ID": {
      "type": "string",
      "description": "One-off session override for immediate control actions"
    },
    "STREAM555_REQUIRE_APPROVALS": {
      "type": "boolean",
      "description": "Require approvals for dangerous stream operations",
      "default": true
    },
    "STREAM555_ALLOW_LOCALHOST_APP_URLS": {
      "type": "string",
      "description": "Allow localhost app URLs for STREAM555_GO_LIVE_APP",
      "default": "false"
    },
    "STREAM555_WALLET_AUTH_PREFERRED_CHAIN": {
      "type": "string",
      "description": "Wallet auth chain preference",
      "default": "solana"
    },
    "STREAM555_WALLET_AUTH_ALLOW_PROVISION": {
      "type": "string",
      "description": "Allow sw4p-linked wallet provisioning when no runtime wallet exists",
      "default": "true"
    },
    "STREAM555_WALLET_AUTH_PROVISION_TARGET_CHAIN": {
      "type": "string",
      "description": "Target chain for sw4p-linked wallet provisioning fallback",
      "default": "eth"
    },
    "STREAM555_DEST_SYNC_ON_GO_LIVE": {
      "type": "string",
      "description": "Automatically sync enabled channels before go-live",
      "default": "true"
    },
    "STREAM555_DEST_PUMPFUN_ENABLED": {
