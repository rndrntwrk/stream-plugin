{
  "name": "@rndrntwrk/plugin-555stream",
  "version": "0.1.0-beta.1",
  "description": "elizaOS plugin for controlling 555stream live studio via Agent Control API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE",
    "docs",
    "skills",
    "elizaos.plugin.json"
  ],
  "scripts": {
    "build": "bun run clean && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "release:check": "node ./scripts/release-check.mjs",
    "release:manifest": "node ./scripts/release-manifest.mjs",
    "release:preview": "bun run typecheck && bun run release:check && npm_config_cache=/tmp/npm-cache npm pack --dry-run",
    "prepublishOnly": "bun run build"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "STREAM555_BASE_URL": {
        "type": "string",
        "description": "Legacy unified base URL override. Prefer STREAM555_PUBLIC_BASE_URL, with STREAM555_INTERNAL_BASE_URL reserved for allow-listed internal agents.",
        "required": false
      },
      "STREAM555_PUBLIC_BASE_URL": {
        "type": "string",
        "description": "Public 555 Stream control-plane URL for general agents and operators.",
        "required": false
      },
      "STREAM555_INTERNAL_BASE_URL": {
        "type": "string",
        "description": "Internal 555 Stream control-plane URL for allow-listed internal agents only.",
        "required": false
      },
      "STREAM555_AGENT_API_KEY": {
        "type": "string",
        "description": "Preferred agent API key used to mint and refresh runtime bearer tokens.",
        "required": false,
        "sensitive": true
      },
      "STREAM555_AGENT_TOKEN": {
        "type": "string",
        "description": "Static bearer token fallback when API-key token exchange is unavailable.",
        "required": false,
        "sensitive": true
      },
      "STREAM555_DEFAULT_SESSION_ID": {
        "type": "string",
        "description": "Optional session ID to auto-connect",
        "required": false
      },
      "STREAM555_REQUIRE_APPROVALS": {
        "type": "boolean",
        "description": "Require approval for dangerous actions (start/stop stream, etc.)",
        "default": true
      }
    }
  },
  "elizaos": {
    "displayName": "555 Stream",
    "configSchemaFile": "./config/plugin-config.schema.json",
    "pluginUiSchemaFile": "./config/plugin-ui.schema.json"
  },
  "keywords": [
    "elizaos",
    "elizaos-plugin",
    "plugin",
    "555stream",
    "livestream",
    "streaming",
    "ai-agent",
    "broadcast"
  ],
  "author": "555stream",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rndrntwrk/stream-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/rndrntwrk/stream-plugin/issues"
  },
  "homepage": "https://docs.rndrntwrk.com/555stream",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@elizaos/core": "^1.7.0"
  },
  "dependencies": {
    "ethers": "^6.15.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@elizaos/core": "^1.7.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.0.0"
  }
}
